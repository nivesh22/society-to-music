# ── GCP ──────────────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS="path/to/your/service_account.json"
GCP_PROJECT_ID="your_gcp_project_id_here"
GCP_PROJECT_NUM="your_gcp_project_number_here"
GCS_BUCKET="msba405-society-music-2026"
GCP_REGION="us-central1"

# ── Spark / Dataproc ──────────────────────────────────────────────────────────
# Leave as local[*] for local dev. On Dataproc this is set automatically.
SPARK_MASTER="local[*]"

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT="your_account_identifier"   # e.g. xy12345.us-east-1
SNOWFLAKE_USER="your_snowflake_username"
SNOWFLAKE_PASSWORD="your_snowflake_password"
SNOWFLAKE_ROLE="your_role"                    # e.g. SYSADMIN
SNOWFLAKE_WAREHOUSE="your_warehouse"          # e.g. COMPUTE_WH
SNOWFLAKE_DATABASE="SOCIETY_TO_MUSIC"
SNOWFLAKE_SCHEMA="CURATED"

# ── Git ───────────────────────────────────────────────────────────────────────
GIT_TOKEN="your_github_personal_access_token_here"
GIT_USERNAME="your_github_username_here"
GIT_EMAIL="your_email_here"
GIT_URL="https://github.com/Prof-Rosario-UCLA/team17.git"
